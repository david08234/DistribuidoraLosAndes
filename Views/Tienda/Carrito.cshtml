@model List<DistribuidoraLosAndes.Models.CarritoItem>

@{
    ViewData["Title"] = "Mi Carrito";
}

<div class="container mt-4 mb-5">
    <div class="bg-white p-4 rounded-3 border border-light shadow-sm" style="border-color: #e2e8f0 !important;">

        <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
            <i class="bi bi-cart3 fs-3 me-2 text-dark"></i>
            <h3 class="fw-bold text-dark mb-0" style="letter-spacing: -0.025em;">Mi Carrito de Compras</h3>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x text-muted mb-3" style="font-size: 4rem;"></i>
                <h4 class="fw-bold text-dark">Tu carrito está vacío</h4>
                <p class="text-muted">Parece que aún no has agregado ninguna bebida.</p>
                <a asp-action="Index" class="btn btn-dark mt-3 px-4 py-2 fw-medium" style="background-color: #0f172a; border-radius: 0.375rem;">
                    <i class="bi bi-shop me-1"></i> Ir a la Tienda
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive mb-4">
                <table class="table align-middle text-nowrap">
                    <thead class="table-light">
                        <tr>
                            <th class="text-secondary small fw-semibold">Producto</th>
                            <th class="text-secondary small fw-semibold text-center">Cantidad</th>
                            <th class="text-secondary small fw-semibold text-end">Precio</th>
                            <th class="text-secondary small fw-semibold text-end">Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.ImagenUrl) ? $"https://via.placeholder.com/50?text={item.Nombre ?? "" .Substring(0, 1)}" : item.ImagenUrl)"
                                             class="rounded me-3 object-fit-contain" style="width: 50px; height: 50px; border: 1px solid #e2e8f0;" alt="...">
                                        <h6 class="mb-0 fw-bold text-dark">@item.Nombre</h6>
                                    </div>
                                </td>
                                <td class="text-center fw-medium">
                                    @item.Cantidad
                                </td>
                                <td class="text-end text-muted">Bs. @item.Precio.ToString("0.00")</td>
                                <td class="text-end fw-bold text-dark fs-6">
                                    Bs. @item.SubTotal.ToString("0.00")
                                </td>
                                <td class="text-center">
                                    <form asp-action="EliminarDelCarrito" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.ProductoId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Eliminar">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold fs-5 text-secondary pt-4">Total a Pagar:</td>
                            <td class="text-end fw-bold fs-4 text-dark pt-4">Bs. @ViewBag.Total.ToString("0.00")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-between border-top pt-4">
                <a asp-action="Index" class="btn btn-light border fw-medium px-4 py-2 text-secondary" style="border-radius: 0.375rem;">
                    <i class="bi bi-arrow-left me-1"></i> Seguir comprando
                </a>
                <a asp-controller="Tienda" asp-action="Checkout" class="btn btn-dark fw-bold px-5 py-2 shadow-sm text-decoration-none" style="background-color: #0f172a; border-radius: 0.375rem;">
                    Proceder al Pago <i class="bi bi-credit-card ms-1"></i>
                </a>
            </div>
        }
    </div>
</div>