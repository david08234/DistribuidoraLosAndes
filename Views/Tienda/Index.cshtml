@model IEnumerable<DistribuidoraLosAndes.Models.Producto>
@using Microsoft.AspNetCore.Http
@using System.Text.Json

@{
    ViewData["Title"] = "Tienda";
    var categorias = ViewBag.Categorias as IEnumerable<DistribuidoraLosAndes.Models.Categoria>;
    var categoriaSeleccionada = ViewBag.CategoriaSeleccionada as int?;

    int totalItems = 0;
    var carritoString = Context.Session.GetString("Carrito");
    if (!string.IsNullOrEmpty(carritoString))
    {
        var carritoLista = JsonSerializer.Deserialize<List<DistribuidoraLosAndes.Models.CarritoItem>>(carritoString);
        if (carritoLista != null)
        {
            totalItems = carritoLista.Sum(item => item.Cantidad);
        }
    }
}

<div class="container mt-4">
    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="bg-white p-3 rounded-3 border border-light shadow-sm" style="border-color: #e2e8f0 !important;">
                <h5 class="fw-bold mb-3 ms-2" style="color: #0f172a; letter-spacing: -0.025em;">Filtros</h5>

                <div class="list-group list-group-flush border-0">
                    <a asp-action="Index" asp-route-categoriaId=""
                       class="list-group-item list-group-item-action border-0 py-2 d-flex justify-content-between align-items-center @(categoriaSeleccionada == null ? "fw-bold text-dark" : "text-muted")">
                        Todas las bebidas
                        @if (categoriaSeleccionada == null)
                        {
                            <i class="bi bi-check2"></i>
                        }
                    </a>

                    @if (categorias != null)
                    {
                        foreach (var cat in categorias)
                        {
                            <a asp-action="Index" asp-route-categoriaId="@cat.Id"
                               class="list-group-item list-group-item-action border-0 py-2 d-flex justify-content-between align-items-center @(categoriaSeleccionada == cat.Id ? "fw-bold text-dark" : "text-muted")">
                                @cat.Nombre
                                @if (categoriaSeleccionada == cat.Id)
                                {
                                    <i class="bi bi-check2"></i>
                                }
                            </a>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-md-9">

            <div class="d-flex justify-content-between align-items-center mb-4 ps-2">
                <h5 class="fw-bold text-dark mb-0">Catálogo disponible</h5>

                <a asp-controller="Tienda" asp-action="Carrito" class="btn btn-light border bg-white position-relative px-3 py-2 shadow-sm text-decoration-none" style="border-radius: 0.5rem; color: #0f172a;">
                    <i class="bi bi-cart3 fs-5"></i>
                    <span class="fw-medium ms-1">Mi Carrito</span>

                    @if (totalItems > 0)
                    {
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light">
                            @totalItems
                        </span>
                    }
                </a>
            </div>

            <form asp-action="Index" method="get" class="mb-4 ps-2" id="formBuscar">
                @if (categoriaSeleccionada != null)
                {
                    <input type="hidden" name="categoriaId" value="@categoriaSeleccionada" />
                }

                <div class="input-group shadow-sm rounded-pill overflow-hidden border" style="border-color: #e2e8f0 !important; background: white;">
                    <input type="text" name="busqueda" id="txtBuscar" class="form-control border-0 ps-4 py-2" placeholder="Busca productos, ej. 'Agua'..." />

                    <button class="btn btn-white border-0 bg-white text-muted px-3" type="button" id="btnMicrofono" title="Buscar por voz">
                        <i class="bi bi-mic-fill fs-5" id="iconoMicro" style="color: #ef4444;"></i>
                    </button>

                    <button class="btn btn-dark px-4 py-2" type="submit" id="btnBuscar" style="background-color: #0f172a;">
                        <i class="bi bi-search me-2"></i>Buscar
                    </button>
                </div>
                <small id="estadoVoz" class="text-danger d-block mt-2 ps-3 d-none fw-medium text-pulse">
                    <i class="bi bi-soundwave me-1"></i>Escuchando... habla ahora.
                </small>
            </form>

            <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
                @if (!Model.Any())
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
                        <h5 class="text-muted mt-3">No hay productos que coincidan con tu búsqueda.</h5>
                    </div>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <div class="col">
                            <div class="card h-100 border-light shadow-sm rounded-3 transition-hover" style="border-color: #e2e8f0 !important;">
                                <img src="@(string.IsNullOrEmpty(item.ImagenUrl) ? $"https://via.placeholder.com/300x300?text={item.Nombre}" : item.ImagenUrl)"
                                     class="card-img-top p-3" alt="@item.Nombre" style="height: 200px; object-fit: contain;">

                                <div class="card-body d-flex flex-column pt-0">
                                    <span class="badge bg-light text-secondary border mb-2 align-self-start">@item.Categoria?.Nombre</span>
                                    <h6 class="card-title fw-bold text-dark mb-1">@item.Nombre</h6>
                                    <p class="card-text small text-muted mb-3 line-clamp-2">@(item.Descripcion ?? "Sin descripción")</p>

                                    <div class="mt-auto">
                                        <h5 class="fw-bold text-dark mb-3">Bs. @item.Precio.ToString("0.00")</h5>

                                        <form asp-controller="Tienda" asp-action="AgregarAlCarrito" method="post">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-dark w-100 fw-medium shadow-sm py-2" style="background-color: #0f172a; border-radius: 0.375rem;">
                                                <i class="bi bi-cart-plus me-1"></i> Agregar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.08) !important;
        }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .text-pulse {
        animation: pulse 1.2s infinite;
    }

    /* Visual Studio marcará esto amarillo, ¡es normal! Ignóralo y compila. */
    @@keyframes pulse {
        0% {opacity: 0.4;}

        50% {opacity: 1;}

        100% {opacity: 0.4;}
    }
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btnMicrofono = document.getElementById("btnMicrofono");
            const iconoMicro = document.getElementById("iconoMicro");
            const txtBuscar = document.getElementById("txtBuscar");
            const estadoVoz = document.getElementById("estadoVoz");
            const formBuscar = document.getElementById("formBuscar");

            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

            if (!SpeechRecognition) {
                console.warn("La API de voz no está soportada en este navegador.");
                btnMicrofono.style.display = "none";
                return;
            }

            const recognition = new SpeechRecognition();
            recognition.lang = 'es-BO';
            recognition.continuous = false;
            recognition.interimResults = false;

            btnMicrofono.addEventListener("click", function () {
                try {
                    recognition.start();
                } catch (e) {
                    console.log("El micrófono ya estaba escuchando.");
                }
            });

            recognition.onstart = function () {
                estadoVoz.classList.remove("d-none");
                iconoMicro.classList.replace("bi-mic-fill", "bi-record-fill");
            };

            recognition.onresult = function (event) {
                const textoEscuchado = event.results[0][0].transcript;
                txtBuscar.value = textoEscuchado.replace(/\.$/, '');
                formBuscar.submit();
            };

            recognition.onend = function () {
                estadoVoz.classList.add("d-none");
                iconoMicro.classList.replace("bi-record-fill", "bi-mic-fill");
            };

            recognition.onerror = function (event) {
                console.error("Error en micrófono: ", event.error);
                estadoVoz.classList.add("d-none");
                iconoMicro.classList.replace("bi-record-fill", "bi-mic-fill");
            };
        });
    </script>
}