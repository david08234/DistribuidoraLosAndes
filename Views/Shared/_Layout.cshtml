<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Los Andes</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="manifest" href="~/manifest.json" />

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: #f8fafc;
            min-height: 100vh;
            padding-bottom: 2rem;
            color: #0f172a;
        }

        .navbar-minimalist {
            background-color: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        }

        .card-custom {
            border: 1px solid #e2e8f0;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            transition: transform 0.2s, box-shadow 0.2s;
            background: #ffffff;
            color: #0f172a;
        }

            .card-custom:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            }

        footer {
            background: transparent;
            color: #64748b;
            text-align: center;
            margin-top: 3rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light navbar-minimalist">
            <div class="container">
                <a class="navbar-brand fw-bold text-dark" asp-area="" asp-controller="Tienda" asp-action="Index">
                    Los Andes
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @{
                        // AQUÍ RECUPERAMOS LOS DATOS DE LA SESIÓN
                        var usuarioId = Context.Session.GetString("UsuarioId");
                        var usuarioNombre = Context.Session.GetString("UsuarioNombre");
                        var usuarioRol = Context.Session.GetString("UsuarioRol"); // <- NUEVO CANDADO
                    }

                    <ul class="navbar-nav flex-grow-1 align-items-center">

                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle text-dark fw-bold" href="#" id="menuCategorias" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-list-ul me-1"></i>Categorías
                            </a>
                            <ul class="dropdown-menu shadow border-0 mt-2" aria-labelledby="menuCategorias" style="border-radius: 0.5rem; min-width: 220px;">
                                <li>
                                    <a class="dropdown-item py-2 fw-bold" asp-controller="Tienda" asp-action="Index" style="color: #0f172a;">
                                        Ver todo el catálogo
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" asp-controller="Tienda" asp-action="Index">
                                <i class="Tienda"></i>Tienda
                            </a>
                        </li>

                        @if (!string.IsNullOrEmpty(usuarioId))
                        {
                            <li class="nav-item ms-2">
                                <a class="nav-link text-dark fw-medium" asp-controller="Tienda" asp-action="MisCompras">
                                    <i class="Compras"></i>Mis Compras
                                </a>
                            </li>

                            // ESTE ES EL CANDADO: SOLO LOS ADMINISTRADORES VEN ESTO
                            @if (usuarioRol == "Administrador")
                            {
                                <li class="nav-item ms-3 border-start ps-3">
                                    <a class="nav-link text-dark fw-medium" asp-controller="Categorias" asp-action="Index">
                                        <i class="Admin_categoria"></i>Admin. Categorías
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-medium" asp-controller="Productos" asp-action="Index">
                                        <i class="Admin. Productos"></i>Admin. Productos
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-medium" asp-controller="Reportes" asp-action="Index">
                                        <i class="Reportes"></i>Reportes
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (!string.IsNullOrEmpty(usuarioId))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center" href="#" id="perfilDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle fs-5 me-2" style="color: #667eea;"></i>
                                    @usuarioNombre
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="perfilDropdown" style="border-radius: 0.5rem; min-width: 200px;">
                                    <li>
                                        <a class="dropdown-item text-danger fw-medium py-2" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-dark px-4 rounded-pill fw-medium shadow-sm" style="background-color: #0f172a;" asp-controller="Account" asp-action="Login">
                                    Iniciar Sesión
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <small>© @DateTime.Now.Year - Distribuidora Los Andes</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('PWA: Service Worker registrado con éxito', reg))
                    .catch(err => console.error('PWA: Error al registrar el Service Worker', err));
            });
        }
    </script>
</body>
</html>