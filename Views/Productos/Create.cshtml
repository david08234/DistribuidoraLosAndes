@model DistribuidoraLosAndes.Models.Producto

@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="bg-white p-4 rounded-3 border border-light shadow-sm">

                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                    <h4 class="fw-bold text-dark mb-0">Registrar Nueva Bebida</h4>
                    <a asp-action="Index" class="btn btn-sm btn-light border text-secondary">Volver al inventario</a>
                </div>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="Nombre" class="form-label small fw-medium text-secondary">Nombre del Producto</label>
                            <input asp-for="Nombre" class="form-control shadcn-input" placeholder="Ej: Cerveza Paceña Lata 354ml" required />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="CategoriaId" class="form-label small fw-medium text-secondary">Categoría</label>
                            <select asp-for="CategoriaId" class="form-select shadcn-input" asp-items="ViewBag.CategoriaId" required>
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Precio" class="form-label small fw-medium text-secondary">Precio (Bs.)</label>
                            <input asp-for="Precio" type="number" step="0.50" class="form-control shadcn-input" placeholder="Ej: 15.50" required />
                            <span asp-validation-for="Precio" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Stock" class="form-label small fw-medium text-secondary">Cantidad en Stock</label>
                            <input asp-for="Stock" type="number" class="form-control shadcn-input" placeholder="Ej: 50" required />
                            <span asp-validation-for="Stock" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label small fw-medium text-secondary">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control shadcn-input" rows="2" placeholder="Detalles de la bebida..."></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImagenUrl" class="form-label small fw-medium text-secondary">URL de la Imagen (Opcional por ahora)</label>
                        <input asp-for="ImagenUrl" class="form-control shadcn-input" placeholder="https://ejemplo.com/botella.jpg" />
                        <div class="form-text small">se puede hacer o no para subir archivos directamente pero falta .</div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 fw-medium py-2" style="background-color: #0f172a;">
                        Guardar Producto
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

<style>
    .shadcn-input {
        border: 1px solid #e2e8f0;
        border-radius: 0.375rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        color: #0f172a;
    }

        .shadcn-input:focus {
            border-color: #94a3b8;
            box-shadow: 0 0 0 2px rgba(148, 163, 184, 0.1);
        }
</style>