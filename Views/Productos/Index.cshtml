@model IEnumerable<DistribuidoraLosAndes.Models.Producto>

@{
    ViewData["Title"] = "Inventario de Productos";
}

<div class="container mt-4">
    <div class="bg-white p-4 rounded-3 border border-light shadow-sm">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-0" style="letter-spacing: -0.025em;">Inventario de Bebidas</h3>
                <p class="text-muted small mb-0">Administra el catálogo y los precios de tu distribuidora.</p>
            </div>
            <a asp-action="Create" class="btn btn-dark fw-medium" style="background-color: #0f172a; border-radius: 0.375rem;">
                <i class="bi bi-plus-lg me-1"></i> Nuevo Producto
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="text-secondary small fw-semibold">Producto</th>
                        <th class="text-secondary small fw-semibold">Categoría</th>
                        <th class="text-secondary small fw-semibold">Precio</th>
                        <th class="text-secondary small fw-semibold">Stock</th>
                        <th class="text-secondary small fw-semibold text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-box-seam mb-2" style="font-size: 2rem;"></i>
                                <p class="mb-0">Tu almacén está vacío. ¡Agrega tu primera bebida!</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark">
                                    <img src="@(string.IsNullOrEmpty(item.ImagenUrl) ? $"https://via.placeholder.com/40?text={item.Nombre.Substring(0, 1)}" : item.ImagenUrl)"
                                         class="rounded me-2 object-fit-cover" style="width: 40px; height: 40px;" alt="...">
                                    @item.Nombre
                                </td>
                                <td><span class="badge bg-light text-secondary border">@item.Categoria?.Nombre</span></td>
                                <td class="fw-medium">Bs. @item.Precio.ToString("0.00")</td>
                                <td>
                                    @if (item.Stock < 10)
                                    {
                                        <span class="text-danger fw-bold">@item.Stock <i class="bi bi-exclamation-triangle ms-1"></i></span>
                                    }
                                    else
                                    {
                                        <span class="text-success">@item.Stock</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border me-1 text-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>