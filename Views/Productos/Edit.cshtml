@model DistribuidoraLosAndes.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="bg-white p-4 rounded-3 border border-light shadow-sm">

                <h4 class="fw-bold mb-4 text-dark"><i class="bi bi-pencil-square text-warning me-2"></i>Editar Producto</h4>

                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImagenUrl" />

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre del producto *</label>
                        <input asp-for="Nombre" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoriaId" class="form-label fw-semibold">Categoría *</label>
                        <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId" required></select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Stock" class="form-label fw-semibold">Stock (Cantidad) *</label>
                            <input asp-for="Stock" type="number" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Precio" class="form-label fw-semibold">Precio (Bs.) *</label>
                            <input asp-for="Precio" type="number" step="0.01" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImagenArchivo" class="form-label fw-semibold">Actualizar Imagen desde PC</label>
                        <input asp-for="ImagenArchivo" type="file" class="form-control" accept="image/*" />
                        <div class="form-text small text-muted">Si no seleccionas ningún archivo, se mantendrá la imagen actual de la bebida.</div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light border text-secondary px-4">Cancelar</a>
                        <button type="submit" class="btn btn-warning fw-bold px-4">Guardar Cambios</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>