@model DistribuidoraLosAndes.Models.Categoria

@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="bg-white p-4 rounded-3 border border-light shadow-sm">

                <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                    <h4 class="fw-bold text-dark mb-0">Registrar Categoría</h4>
                    <a asp-action="Index" class="btn btn-sm btn-light border text-secondary">Volver a la lista</a>
                </div>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label small fw-medium text-secondary">Nombre de la Categoría</label>
                        <input asp-for="Nombre" class="form-control shadcn-input" placeholder="Ej: Cervezas, Rones, Gaseosas..." required />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Descripcion" class="form-label small fw-medium text-secondary">Descripción (Opcional)</label>
                        <textarea asp-for="Descripcion" class="form-control shadcn-input" rows="3" placeholder="Breve descripción de los productos..."></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 fw-medium py-2" style="background-color: #0f172a;">
                        Guardar Categoría
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

<style>
    .shadcn-input {
        border: 1px solid #e2e8f0;
        border-radius: 0.375rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        color: #0f172a;
    }

        .shadcn-input:focus {
            border-color: #94a3b8;
            box-shadow: 0 0 0 2px rgba(148, 163, 184, 0.1);
        }
</style>