@model DistribuidoraLosAndes.Models.Categoria

@{
    ViewData["Title"] = "Eliminar Categoría";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="bg-white p-4 rounded-3 border border-light shadow-sm text-center">

                <i class="bi bi-exclamation-triangle-fill text-danger mb-3" style="font-size: 3.5rem;"></i>
                <h4 class="fw-bold text-dark mb-2">¿Eliminar Categoría?</h4>
                <p class="text-muted mb-4">
                    Estás a punto de eliminar la categoría <strong class="text-dark">@Model.Nombre</strong>.
                    <br />Esta acción no se puede deshacer.
                </p>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex justify-content-center gap-3 border-top pt-4">
                        <a asp-action="Index" class="btn btn-light border text-secondary px-4">Cancelar</a>
                        <button type="submit" class="btn btn-danger fw-bold px-4">Sí, eliminar</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>